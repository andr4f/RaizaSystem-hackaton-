# Variables de entorno para Railway (backend — servicio demo/)
#
# SPRING_PROFILES_ACTIVE=prod
# PGHOST=${{Postgres.PGHOST}}
# PGPORT=${{Postgres.PGPORT}}
# PGUSER=${{Postgres.PGUSER}}
# PGPASSWORD=${{Postgres.PGPASSWORD}}
# PGDATABASE=${{Postgres.PGDATABASE}}
# JWT_SECRET=<openssl rand -base64 64>
#
# ⚠️ OBLIGATORIO para el chat — copia el valor de tu key Groq (gsk_...)
#    NO subas application-local.properties al repo; pégala aquí en Railway:
# GROQ_API_KEY=gsk_tu_key_aqui
#
# APP_CORS_ORIGINS=https://<tu-front>.up.railway.app
# PDF_STORAGE_PATH=/tmp/pdfs
#
# Variables de entorno para Railway (frontend — servicio frontend/)
#
# BACKEND_URL=https://<tu-api>.up.railway.app
# (sin / al final — debe ser https://)
